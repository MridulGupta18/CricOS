{
  "expo": {
    "name": "CricOS",
    "slug": "cricket-os",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F1A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.crivos.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "CricOS uses the camera to scan QR codes for joining leagues.",
        "NSPhotoLibraryUsageDescription": "CricOS uses your photo library to set a profile picture."
      }
    },
    "android": {
      "package": "com.crivos.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0F1A"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "crivos.app", "pathPrefix": "/" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        { "backgroundColor": "#0B0F1A", "image": "./assets/splash.png", "imageWidth": 200 }
      ]
    ],
    "scheme": "crivos",
    "experiments": {
      "typedRoutes": true
    }
  }
}
