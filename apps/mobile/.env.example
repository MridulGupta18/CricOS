EXPO_PUBLIC_API_URL=http://10.0.2.2:4000
EXPO_PUBLIC_SOCKET_URL=http://10.0.2.2:4000
# Note: 10.0.2.2 is localhost from Android emulator
# For physical device, use your machine's LAN IP e.g. http://192.168.1.x:4000

# Public marketing URLs — App Store / Play Store reviewers tap these.
# Leaving these unset falls back to https://crivos.app/{terms,privacy}.
EXPO_PUBLIC_TERMS_URL=
EXPO_PUBLIC_PRIVACY_URL=
