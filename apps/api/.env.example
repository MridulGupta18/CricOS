# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/cricket_os

# ─── Auth ────────────────────────────────────────────────────
# Required in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
REFRESH_TOKEN_SECRET=

# ─── CORS / Frontend ─────────────────────────────────────────
# Comma-separated allowlist of frontend origins. Mobile (no Origin header)
# is always allowed. Set to your production web origin(s).
FRONTEND_URL=http://localhost:3000,http://localhost:8081

# ─── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# ─── Master Account (one-time bootstrap) ─────────────────────
# Email of the user who will be promoted to MASTER via POST /api/v1/admin/bootstrap.
MASTER_EMAIL=

# ─── Payments (Stripe) ───────────────────────────────────────
# Leave empty in dev — checkout endpoints will return 503 instead of crashing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email (Resend) ──────────────────────────────────────────
# Leave empty in dev — verification/reset emails will be logged instead of sent.
RESEND_API_KEY=
EMAIL_FROM="CricOS <no-reply@cricos.app>"

# ─── Observability (optional) ────────────────────────────────
SENTRY_DSN=
