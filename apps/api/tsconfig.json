{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@cricket-os/shared": ["../../packages/shared/src"],
      "@cricket-os/db": ["../../packages/db/src"],
      "@cricket-os/scoring-engine": ["../../packages/scoring-engine/src"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
