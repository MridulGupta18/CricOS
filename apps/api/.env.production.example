# Copy these into Railway → Service → Variables
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

DATABASE_URL=postgresql://user:password@host:5432/railway
JWT_SECRET=replace-with-64-char-random-hex
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://crivos.app

# Optional — only needed if you use Stripe for league payments
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
