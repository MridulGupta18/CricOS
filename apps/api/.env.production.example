# Copy these into Railway → Service → Variables.
# Generate JWT_SECRET & REFRESH_TOKEN_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ─── Required ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/railway
JWT_SECRET=replace-with-64-char-random-hex
REFRESH_TOKEN_SECRET=replace-with-different-64-char-random-hex
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://crivos.app

# Email of the account to be promoted via POST /api/v1/admin/bootstrap.
MASTER_EMAIL=admin@yourcompany.com

# ─── Payments (Stripe) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM="CricOS <no-reply@yourdomain.com>"

# ─── Observability ───────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
