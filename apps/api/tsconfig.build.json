{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true,
    "removeComments": false
  },
  "include": [
    "src/**/*",
    "../../packages/shared/src/**/*",
    "../../packages/scoring-engine/src/**/*",
    "../../packages/db/src/**/*"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
