{
  "name": "@cricket-os/api",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate --schema=../../packages/db/prisma/schema.prisma && tsup",
    "start": "node dist/index.js",
    "start:dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:calgary": "tsx scripts/seed-calgary-league.ts",
    "seed:calgary:prod": "tsx scripts/seed-calgary-league.ts --api https://cricosmridulgupta18-production.up.railway.app"
  },
  "dependencies": {
    "@cricket-os/db": "*",
    "@cricket-os/shared": "*",
    "@cricket-os/scoring-engine": "*",
    "@sentry/node": "^8.40.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "socket.io": "^4.7.0",
    "stripe": "^15.7.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/uuid": "^9.0.8",
    "pino-pretty": "^11.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
